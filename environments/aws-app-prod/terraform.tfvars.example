# Copy to terraform.tfvars and fill in.
#   cp terraform.tfvars.example terraform.tfvars
#   # Replace ssh_public_key with output of: cat ~/.ssh/id_rsa.pub
# terraform.tfvars is gitignored.

aws_region   = "ap-northeast-2"
project_name = "mek-lab"
environment  = "app-prod"

# Distinct from aws-app-dev (10.0/16) and aws-monitoring-prod (10.1/16).
vpc_cidr           = "10.2.0.0/16"
public_subnet_cidr = "10.2.1.0/24"

key_name = "mek-lab-app-prod-key"

# Paste your SSH public key (e.g. contents of ~/.ssh/id_rsa.pub or ~/.ssh/id_ed25519.pub)
ssh_public_key = "ssh-ed25519 AAAA... your-key"

# Optional: tighten access in production.
# allowed_ssh_cidrs        = ["1.2.3.4/32"]
# allowed_http_cidrs       = ["0.0.0.0/0"]
# allowed_app_cidrs        = ["0.0.0.0/0"]
# allowed_monitoring_cidrs = ["10.1.0.0/16"]   # only the monitoring VPC

# Sizing mirrors GCP source hosts (2 vCPU / ~4 GB) with headroom on AWS (8 GB on t3.large).
backend_instance_type       = "t3.large"
backend_root_volume_size_gb = 50
salome_instance_type        = "t3.large"
salome_root_volume_size_gb  = 50
root_volume_type            = "gp3"

tags = {
  Owner = "platform-team"
}
